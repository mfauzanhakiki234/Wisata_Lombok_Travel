{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-laravel",
            "config": {
                "maxExecutionTime": 60,
                "phpVersion": "8.3"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}